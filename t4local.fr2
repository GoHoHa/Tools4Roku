        26  => "Nuageux",
        27  => "Très nuageux",
        28  => "Très nuageux",
        29  => "Nuit claire",
        30  => "Ensoleillé",
        31  => "Nuit claire",
        32  => "Ensoleillé",
        33  => "Nuit mitigé",
