# Rating songs
our $ilikeit		= "C'est ma chanson préférée";
our $notmytaste		= "Question de goût...";
our $nosongtorate	= "No song to rate";
our $itsremotestream	= "Its a net-radio.";

# Threshhold for similar artist selection
our $threshhold 	= 50; # Must have similarity in percent
our $similarartists1	= "Generate new plazlist of similar arists";
our $similarartists2	= "(thanks to audioscrobbler.com)";
our $lookforsimartist	= "Who is like ";
