################################################################################
#
# Tools4Roku localization file 
# Traduction par Guillaume Membré
#

use strict;

########################################################################
# Editez ici si besoin

# adresse ip du roku
our $rokuIP = '192.168.xxx.yyy';

# Type d'affichage du Soundbridge
#   En cas de doute, se connecter en telnet sur le roku sur le port 4444 et
#   taper "displaytype" 
#   * 0 = LCD Character OR String Character = 40 x 2                  
#     1 = Small VFD Bitmap OR Small VFD Direct Bitmap = 280 x 16         
#     2 = Small and Tall VFD Direct Bitmap = 280 x 32
#   * 3 = Large VFD Bitmap = 512 x 32  
#   * NOT YET READY !              
our $displaytype = 2;
 
# selectionner le mode dans lequel RokuTools doit demarrer apres un 
# reboot
#  0 - meteo actuelle
#  1 - meteo d'aujourd'hui et de demain
#  2 - vue compacte de toute les données
#  3 - heure
our $modus = 0;

# alternance automatique des ecrans en multiple de 10 secondes, 
#  0 = desactivé
our $alternate = 6;

# code de localisation cf http://weather.yahoo.com/
our $locationid = "JAXX0085";

# unité : c pour systeme metrique, f pour systeme non metrique
our $unitsid = "c";

# active l'utilisation d'une sonde digitemp (cf www.digitemp.com)
# Oui = 1 , Non = 0
our $digitemp = 0;

# Direction du vent
# Ce tableau peut etre etendu afin d'avoir 4, 8, 16 ou 32 entrée. Le programme 
# se debrouillera
our @direction = ( 'N',
                   'NE',
                   'E',
                   'SE',
                   'S',
                   'SO',
                   'O',
                   'NO');

# Jour de la semaine abrege
our %dayname =  ('Mon' => 'Lun',
                 'Tue' => 'Mar',
                 'Wed' => 'Mer',
                 'Thu' => 'Jeu',
                 'Fri' => 'Ven',
                 'Sat' => 'Sam',
                 'Sun' => 'Dim'             
               );
               
# Mois de l'année
our %monname =  ('Jan' => 'Janvier',
                 'Feb' => 'Février',
                 'Mar' => 'Mars',
                 'Apr' => 'Avril',
                 'May' => 'Mai',
                 'Jun' => 'Juin',
                 'Jul' => 'Juillet',
                 'Aug' => 'Aout',
                 'Sep' => 'Septembre',
                 'Oct' => 'Octobre',
                 'Nov' => 'Novembre',
                 'Dec' => 'Décembre',
               );
               
